# Supabase — obtén estos valores en app.supabase.com > Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role (NUNCA expongas al frontend — solo API/server)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Mercado Pago — obtén el Access Token en:
# mercadopago.com.pe > Tu negocio > Configuración > Credenciales
# Usa el Access Token de PRODUCCIÓN para producción, o el de PRUEBA para testing
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

# URL de tu app (en Vercel será algo como https://neurokids.vercel.app)
VITE_APP_URL=http://localhost:5173
