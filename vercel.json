{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/checkout.js": { "memory": 256, "maxDuration": 15 },
    "api/webhook.js":  { "memory": 256, "maxDuration": 10 },
    "api/download.js": { "memory": 256, "maxDuration": 10 },
    "api/health.js":   { "memory": 128, "maxDuration": 5  }
  }
}
